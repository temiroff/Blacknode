    "calc": {
      "id": "calc",
      "type": "PythonFn",
      "params": {
        "code": "def run(expression: str) -> str:\n    import ast, math, operator\n    ops = {ast.Add: operator.add, ast.Sub: operator.sub, ast.Mult: operator.mul,\n           ast.Div: operator.truediv, ast.Pow: operator.pow, ast.Mod: operator.mod,\n           ast.FloorDiv: operator.floordiv, ast.USub: operator.neg, ast.UAdd: operator.pos}\n    funcs = {k: getattr(math, k) for k in\n             (\"sqrt\", \"sin\", \"cos\", \"tan\", \"log\", \"log10\", \"exp\", \"floor\", \"ceil\", \"fabs\")}\n    names = {\"pi\": math.pi, \"e\": math.e, \"tau\": math.tau}\n\n    def ev(node):\n        if isinstance(node, ast.Expression):\n            return ev(node.body)\n        if isinstance(node, ast.Constant):\n            return node.value\n        if isinstance(node, ast.BinOp):\n            return ops[type(node.op)](ev(node.left), ev(node.right))\n        if isinstance(node, ast.UnaryOp):\n            return ops[type(node.op)](ev(node.operand))\n        if isinstance(node, ast.Name):\n            return names[node.id]\n        if isinstance(node, ast.Call) and isinstance(node.func, ast.Name):\n            return funcs[node.func.id](*[ev(a) for a in node.args])\n        raise ValueError(\"unsupported expression\")\n\n    try:\n        return str(ev(ast.parse(str(expression), mode=\"eval\")))\n    except Exception as exc:\n        return \"calc error: \" + str(exc)\n",
        "name": "calculator",
        "description": "Evaluate a safe arithmetic expression (supports + - * / ** %, sqrt, sin, log, pi, e).",
        "label": "calculator"
